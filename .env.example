# Velocity forwarding secret (plain text)
FORWARDING_SECRET=

# Floodgate key in PEM format. Use \n for newlines.
FLOODGATE_KEY_PEM=

# MariaDB root password (for docker-compose)
MARIADB_ROOT_PASSWORD=

# LuckPerms MySQL database
# Use mariadb:3306 for Docker, 127.0.0.1:3306 for local
LUCKPERMS_DB_HOST=127.0.0.1:3306
LUCKPERMS_DB_NAME=luckperms_2b2t
LUCKPERMS_DB_USER=lpsql
LUCKPERMS_DB_PASSWORD=

# TAB MySQL database (disabled by default, enable in TAB config)
TAB_DB_NAME=tab
TAB_DB_USER=user
TAB_DB_PASSWORD=

# AuthMe MySQL database (lobby server)
AUTHME_DB_HOST=127.0.0.1
AUTHME_DB_NAME=authme
AUTHME_DB_USER=authme
AUTHME_DB_PASSWORD=
